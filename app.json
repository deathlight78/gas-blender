{
  "expo": {
    "name": "Gas Blender",
    "slug": "gas-blender",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#003366"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gasblender.app"
    },
    "android": {
      "package": "com.gasblender.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#003366"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "jsEngine": "jsc"
    },
    "scheme": "gas-blender",
    "plugins": ["expo-router"],
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
